# Application Environment Variables
# Copy this file to .env and fill in the values.
# Note: The PHP built-in server does not load .env files automatically.
# Use a library like vlucas/phpdotenv (composer) or set vars in your web server config.

# ---- Application ----
APP_NAME="Coliconstruct Engineering Services"
APP_ENV=local         # local | production
APP_DEBUG=true        # true | false
APP_URL=http://localhost:8000

# ---- Session ----
# PHP sessions are file-based by default. To use another handler set these.
# SESSION_DRIVER=file
# SESSION_LIFETIME=120     # minutes

# ---- Database (optional – SQLite for local dev) ----
# If you extend the app to use a real database, set these.
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/coliconstruct.sqlite

# ---- Mail (optional) ----
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@coliconstruct.com
# MAIL_FROM_NAME="${APP_NAME}"
